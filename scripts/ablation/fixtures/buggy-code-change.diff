-export async function authenticateUser(email: string, password: string) {
-  const user = await db.users.findOne({ email });
+export async function authenticateUser(email: string, password: string, rememberMe?: boolean) {
+  const user = await db.users.findOne({ email: email.trim() });
+  if (!user) {
+    return { success: false, error: "Invalid credentials" };
+  }
+
+  const isValid = await verifyPassword(password, user.passwordHash);
+  if (!isValid) {
+    return { success: false, error: "Invalid credentials" };
+  }
+
+  const sessionDuration = rememberMe ? 30 * 24 * 60 * 60 : 3600;
+  const session = await createSession(user.id, { expiresIn: sessionDuration });
+
+  await db.users.updateOne({ email }, { $set: { lastLogin: new Date() } });
+
+  return { success: true, user: { id: user.id, email: user.email, role: user.role }, token: session.token };
+}
+
+export async function deleteUserAccount(userId: string) {
+  const user = await db.users.findById(userId);
+  if (!user) throw new Error("User not found");
+
+  await db.orders.deleteMany({ userId });
+  await db.sessions.deleteMany({ userId });
+  await db.users.deleteOne({ _id: userId });

-  if (!user) return null;
-  return user;
+  return { deleted: true, email: user.email };
 }
diff --git a/src/api/payments.ts b/src/api/payments.ts
new file mode 100644
index 0000000..abc1234
--- /dev/null
+++ b/src/api/payments.ts
@@ -0,0 +1,45 @@
+import { db } from "../database";
+import Stripe from "stripe";
+
+const stripe = new Stripe(process.env.STRIPE_KEY!);
+
+export async function processPayment(userId: string, amount: number, currency: string) {
+  const user = await db.users.findById(userId);
+  if (!user) throw new Error("User not found");
+
+  const paymentIntent = await stripe.paymentIntents.create({
+    amount: amount,
+    currency: currency,
+    customer: user.stripeCustomerId,
+    metadata: { userId },
+  });
+
+  await db.payments.insertOne({
+    userId,
+    amount,
+    currency,
+    stripePaymentId: paymentIntent.id,
+    status: "pending",
+    createdAt: new Date(),
+  });
+
+  return { clientSecret: paymentIntent.client_secret, paymentId: paymentIntent.id };
+}
+
+export async function refundPayment(paymentId: string, reason?: string) {
+  const payment = await db.payments.findOne({ stripePaymentId: paymentId });
+  if (!payment) throw new Error("Payment not found");
+
+  const refund = await stripe.refunds.create({
+    payment_intent: paymentId,
+    reason: reason as any,
+  });
+
+  await db.payments.updateOne(
+    { stripePaymentId: paymentId },
+    { $set: { status: "refunded", refundId: refund.id } },
+  );
+
+  return { refunded: true, refundId: refund.id };
+}
+
+export async function getPaymentHistory(userId: string, page = 1) {
+  const pageSize = 50;
+  const payments = await db.payments.find({ userId }).skip((page - 1) * pageSize).limit(pageSize).toArray();
+  return payments;
+}
